{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account for authentication and basic profile.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "hr", "manager", "employee"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "role"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Comprehensive employee record.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "departmentId": { "type": "string" },
        "jobTitle": { "type": "string" },
        "hireDate": { "type": "string", "format": "date" },
        "salary": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "terminated", "furloughed", "on-leave"] },
        "managerId": { "type": "string" }
      },
      "required": ["employeeId", "firstName", "lastName", "departmentId", "jobTitle", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Clock in/out records.",
      "type": "object",
      "properties": {
        "attendanceId": { "type": "string" },
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "clockIn": { "type": "string", "format": "date-time" },
        "clockOut": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "absent", "late", "half-day"] }
      },
      "required": ["employeeId", "date", "clockIn"]
    },
    "Leave": {
      "title": "Leave",
      "description": "Leave requests and approvals.",
      "type": "object",
      "properties": {
        "leaveId": { "type": "string" },
        "employeeId": { "type": "string" },
        "type": { "type": "string", "enum": ["annual", "sick", "unpaid", "maternity", "study"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "reason": { "type": "string" },
        "approvedBy": { "type": "string" }
      },
      "required": ["employeeId", "type", "startDate", "endDate", "status"]
    },
    "Payroll": {
      "title": "Payroll",
      "description": "Monthly payroll records.",
      "type": "object",
      "properties": {
        "payrollId": { "type": "string" },
        "employeeId": { "type": "string" },
        "month": { "type": "string" },
        "year": { "type": "number" },
        "baseSalary": { "type": "number" },
        "bonus": { "type": "number" },
        "deductions": { "type": "number" },
        "netSalary": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "paid"] }
      },
      "required": ["employeeId", "month", "year", "netSalary", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Employee records."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance logs."
    },
    "/leaves/{leaveId}": {
      "schema": "Leave",
      "description": "Leave requests."
    },
    "/payroll/{payrollId}": {
      "schema": "Payroll",
      "description": "Monthly payroll."
    }
  }
}
